{
  "compilerOptions": {
    "target": "ES2020",
    "useDefineForClassFields": true,
    "lib": ["ES2020", "DOM", "DOM.Iterable"],
    "module": "ESNext",
    "skipLibCheck": true,

    /* Bundler mode */
    "moduleResolution": "bundler",
    "allowImportingTsExtensions": true,
    "resolveJsonModule": true,
    "isolatedModules": true,
    "noEmit": true,
    "jsx": "react-jsx",

    /* Linting */
    "strict": true,
    "noImplicitAny": true,
    "noUnusedLocals": true,
    "noUnusedParameters": true,
    "noFallthroughCasesInSwitch": true,

    /* Paths */
    "baseUrl": ".",
    "paths": {
      "@/*": ["src/*"],
      "@shared/components": ["../softbits-shared/components/index.ts"],
      "@shared/components/*": ["../softbits-shared/components/*"],
      "@shared/hooks": ["../softbits-shared/hooks/index.ts"],
      "@shared/hooks/*": ["../softbits-shared/hooks/*"]
    }
  },
  "include": ["src"],
  "exclude": ["../softbits-shared"],
  "references": [{ "path": "./tsconfig.node.json" }]
}
